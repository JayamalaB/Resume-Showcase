{
  "compilerOptions": {
    "outDir": "server-dist",
    "rootDir": "server",
    "module": "ESNext",
    "target": "es2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", "client", "dist", "vite.config.ts"]
}